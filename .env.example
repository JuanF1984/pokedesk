# Vercel AI Gateway — used by app/api/pokemon/[id]/audio to generate MP3
# speech (openai/tts-1) from the Spanish Pokemon description.
# On Vercel deployments this can be left unset: the platform's OIDC token
# authenticates automatically. For local development, create a key at
# https://vercel.com/[team]/~/ai-gateway/api-keys
AI_GATEWAY_API_KEY=

# Vercel Blob — caches generated MP3s so the same audio is never
# regenerated for the same Pokemon description. Auto-provisioned when a
# Blob store is connected to the Vercel project; for local development run
# `vercel env pull .env.local` after connecting one, or paste a
# read-write token here.
BLOB_READ_WRITE_TOKEN=
